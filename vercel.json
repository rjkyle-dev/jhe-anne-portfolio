{
  "buildCommand": "bun run build",
  "outputDirectory": "dist",
  "framework": null,
  "installCommand": "bun install",
  "rewrites": [
    {
      "source": "/assets/(.*)",
      "destination": "/client/assets/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/server/server.js"
    }
  ]
}